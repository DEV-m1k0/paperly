# ══════════════════════════════════════════════════════════════════
# Шаблон переменных окружения для Paperly.
# Скопируйте в `.env` и заполните значения.
# На Render / PythonAnywhere — задайте эти же переменные в dashboard.
# ══════════════════════════════════════════════════════════════════

# ── Django core ──
SECRET_KEY=замените-на-случайные-50-символов-минимум
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,ваш-домен.onrender.com
CSRF_TRUSTED_ORIGINS=https://ваш-домен.onrender.com

# ── База данных ──
# Локально: оставьте пустым — будет SQLite (db.sqlite3 в backend/).
# На Render: Render сам подставит postgres:// URL от связанной БД.
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# ── Email (для сброса пароля / newsletter) ──
EMAIL_HOST=smtp.yandex.ru
EMAIL_PORT=465
EMAIL_USE_SSL=True
EMAIL_HOST_USER=your-email@yandex.ru
EMAIL_HOST_PASSWORD=ваш-app-password
DEFAULT_FROM_EMAIL=your-email@yandex.ru

# Media on Render / production.
# Leave USE_S3_MEDIA=False for local development. In production set True and provide
# an S3-compatible bucket: AWS S3, Cloudflare R2, Yandex Object Storage, Spaces, etc.
USE_S3_MEDIA=False
AWS_STORAGE_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_REGION_NAME=auto
AWS_S3_ENDPOINT_URL=
AWS_S3_CUSTOM_DOMAIN=
